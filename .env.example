# API (copy to api/.env)
# База — файл в репозитории api/prisma/glassnet.db (коммитится в GitHub)
DATABASE_URL="file:./glassnet.db"
JWT_SECRET="change-me-min-32-chars-random-string-here"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
MESSAGE_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV=development

# Web (copy to web/.env.local)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Vercel (Production) — только секреты, БД из репозитория:
# JWT_SECRET, JWT_REFRESH_SECRET, MESSAGE_ENCRYPTION_KEY, NODE_ENV=production
# DATABASE_URL и DIRECT_URL на Vercel НЕ нужны
# NEXT_PUBLIC_API_URL не задавайте
