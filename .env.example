# API (copy to api/.env)
# Локально: docker compose up -d  →  Postgres на :5432
DATABASE_URL="postgresql://glassnet:glassnet@localhost:5432/glassnet"
JWT_SECRET="change-me-min-32-chars-random-string-here"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
MESSAGE_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV=development

# Web (copy to web/.env.local)
# Локально — отдельный API. На Vercel не задавайте (будет /backend).
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Vercel / production на одном домене:
# NEXT_PUBLIC_API_URL не нужен — запросы идут на /backend
